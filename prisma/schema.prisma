generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// Styra — Grooming Marketplace Prisma Schema (SQLite)
// ============================================================
// JSON fields are stored as String; parse with JSON.parse() in app code.
// Enums are represented as String types.
// ============================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?
  name          String
  phone         String?
  avatar        String?
  role          String   @default("customer") // customer, business, admin
  isVerified    Boolean  @default(false)
  isBanned      Boolean  @default(false)
  banReason     String?
  tokenVersion  Int      @default(0)
  location      String?  // JSON string
  preferences   String?  // JSON string
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  businesses      Business[]
  bookings        Booking[]
  reviews         Review[]
  favorites       Favorite[]
  notifications   Notification[]
  conversations1  Conversation[] @relation("UserConversations1")
  conversations2  Conversation[] @relation("UserConversations2")
  messages        ChatMessage[]
  payments        Payment[]
  wallet          Wallet?
  oTPCodes        OTPVerification[]
  passwordResets  PasswordReset[]
  insuranceClaims InsuranceClaim[]
  protectionPlan String  @default("basic") // basic, enhanced, premium
}

model Business {
  id              String   @id @default(cuid())
  ownerId         String
  name            String
  description     String?
  category        String
  address         String?
  city            String?
  country         String?
  latitude        Float?
  longitude       Float?
  phone           String?
  email           String?
  website         String?
  logo            String?
  coverImage      String?
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  isVerified      Boolean  @default(false)
  isActive        Boolean  @default(true)
  operatingHours  String?  // JSON string
  amenities       String?  // JSON string
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner     User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  services  Service[]
  staff     Staff[]
  portfolio PortfolioItem[]
  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]
}

model Service {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String?
  price       Float
  duration    Int      // minutes
  category    String?
  isActive    Boolean  @default(true)
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings  Booking[]
}

model Staff {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  role        String?
  avatar      String?
  phone       String?
  email       String?
  bio         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings  Booking[]
}

model PortfolioItem {
  id          String   @id @default(cuid())
  businessId  String
  title       String?
  description String?
  image       String
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Booking {
  id                  String    @id @default(cuid())
  customerId          String
  businessId          String
  serviceId           String?
  staffId             String?
  date                String    // ISO date string
  time                String    // ISO time string
  endTime             String?
  status              String    @default("pending") // pending, confirmed, in_progress, completed, cancelled, disputed
  notes               String?
  totalPrice          Float
  customerName        String?
  customerPhone       String?
  customerEmail       String?
  staffName           String?
  serviceName         String?
  servicePrice        Float?
  disputeReason       String?
  disputeResolvedAt   DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?
  completedAt         DateTime?
  confirmedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  customer User     @relation(fields: [customerId], references: [id])
  business Business @relation(fields: [businessId], references: [id])
  service  Service? @relation(fields: [serviceId], references: [id])
  staff    Staff?   @relation(fields: [staffId], references: [id])
  payments Payment[]
  reviews  Review[]
}

model Payment {
  id              String    @id @default(cuid())
  bookingId       String
  userId          String
  amount          Float
  method          String    // mpesa, card_stripe, card_paystack, paypal
  status          String    @default("pending") // pending, processing, completed, failed, refunded
  transactionRef  String    @unique
  providerRef     String?
  description     String?
  escrowStatus    String    @default("held") // held, released, refunded
  releasedAt      DateTime?
  refundedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model Payout {
  id              String    @id @default(cuid())
  businessId      String
  userId          String
  amount          Float
  method          String    // mpesa, bank_transfer
  status          String    @default("pending") // pending, processing, completed, failed
  transactionRef  String    @unique
  providerRef     String?
  description     String?
  failedReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Review {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  customerId  String
  businessId  String
  rating      Int      // 1-5
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking  Booking @relation(fields: [bookingId], references: [id])
  customer User    @relation(fields: [customerId], references: [id])
  business Business @relation(fields: [businessId], references: [id])
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  businessId  String
  createdAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, booking, payment, review, system
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id            String    @id @default(cuid())
  participant1  String
  participant2  String
  lastMessage   String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user1    User          @relation("UserConversations1", fields: [participant1], references: [id])
  user2    User          @relation("UserConversations2", fields: [participant2], references: [id])
  messages ChatMessage[]
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User        @relation(fields: [senderId], references: [id])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0)
  currency  String   @default("KES")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OTPVerification {
  id        String   @id @default(cuid())
  userId    String?
  phone     String?
  email     String?
  code      String
  purpose   String   // login, register, reset_password
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String?
  details   String?  // JSON string
  ipAddress String?
  createdAt DateTime @default(now())
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InsuranceClaim {
  id            String    @id @default(cuid())
  claimNumber   String    @unique
  userId        String
  userType      String    @default("customer") // customer, provider
  customerName  String
  customerEmail String
  providerId    String?
  providerName  String?
  businessId    String?
  businessName  String?
  bookingId     String?
  type          String    // service_dispute, refund_request, quality_issue, safety_concern, billing_error, no_show, damage, payment_dispute, harassment, policy_violation, other
  description   String
  amount        Float
  currency      String    @default("USD")
  status        String    @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, APPROVED, REJECTED, PAID
  documents     String?   // JSON string
  incidentDate  DateTime?
  adminNotes    String?
  resolution    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  submittedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FormSubmission {
  id        String   @id @default(cuid())
  type      String   // CONTACT, SUPPORT, FEEDBACK, PARTNERSHIP, REPORT, CLAIM, OTHER
  name      String?
  email     String?
  phone     String?
  subject   String?
  message   String?
  category  String?
  userId    String?
  metadata  String?  // JSON string
  status    String   @default("PENDING") // PENDING, REVIEWED, RESOLVED, SPAM
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
